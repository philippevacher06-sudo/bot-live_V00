# AUTO VENV — sécurité lancement tmux / cron / shell propre
# ============================================================
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR" || exit 1

if [ -f "$SCRIPT_DIR/venv/bin/activate" ]; then
    source "$SCRIPT_DIR/venv/bin/activate"
else
    echo "ERREUR: venv introuvable: $SCRIPT_DIR/venv/bin/activate"
    exit 127
fi

PYTHON_BIN="$SCRIPT_DIR/venv/bin/python"
if [ ! -x "$PYTHON_BIN" ]; then
    echo "ERREUR: python venv introuvable: $PYTHON_BIN"
    exit 127
fi

python() {
    "$PYTHON_BIN" "$@"
}

echo "AUTO VENV OK: $(which python) / $(python --version 2>&1)"
