def get_positions_raw(headers: Dict[str, str]) -> List[Dict[str, Any]]:
    status, data = api_get(headers, "/positions")

    if status != 200:
        log("RUNNER_GET_POSITIONS_ERROR", asset=ASSET, status=status, response=data)
        raise RuntimeError(f"GET /positions failed status={status} data={data}")

    positions = data.get("positions", []) if isinstance(data, dict) else []

    log(
        "RUNNER_GET_POSITIONS_OK",
        asset=ASSET,
        status=status,
        total_positions=len(positions),
        raw=data,
    )

    return positions


def position_epic(item: Dict[str, Any]) -> str:
    if not isinstance(item, dict):
        return ""

    market = item.get("market", {}) if isinstance(item.get("market"), dict) else {}
    position = item.get("position", {}) if isinstance(item.get("position"), dict) else {}

    return str(
        market.get("epic")
        or position.get("epic")
        or item.get("epic")
        or ""
    ).upper()


def normalize_position(item: Dict[str, Any]) -> Dict[str, Any]:
    market = item.get("market", {}) if isinstance(item.get("market"), dict) else {}
    position = item.get("position", {}) if isinstance(item.get("position"), dict) else {}

    def fnum(v: Any, default: float = 0.0) -> float:
        try:
            if v is None:
                return default
            return float(v)
        except Exception:
            return default

    return {
        "epic": str(market.get("epic") or position.get("epic") or item.get("epic") or "").upper(),
        "dealId": position.get("dealId") or item.get("dealId"),
        "dealReference": position.get("dealReference") or item.get("dealReference"),
        "workingOrderId": position.get("workingOrderId") or item.get("workingOrderId"),
        "size": fnum(position.get("size") or item.get("size")),
        "direction": position.get("direction") or item.get("direction"),
        "level": fnum(position.get("level") or item.get("level")),
        "upl": fnum(position.get("upl") or item.get("upl")),
        "guaranteedStop": bool(position.get("guaranteedStop") or item.get("guaranteedStop")),
        "raw": item,
    }


def asset_positions(headers: Dict[str, str], asset: str = ASSET) -> List[Dict[str, Any]]:
    raw_positions = get_positions_raw(headers)
    out: List[Dict[str, Any]] = []

    for item in raw_positions:
        epic = position_epic(item)

        if epic in PROTECTED_ASSETS:
            continue

        if epic == asset:
            out.append(normalize_position(item))

    log(
        "RUNNER_ASSET_POSITIONS",
        asset=asset,
        count=len(out),
        dealIds=[p.get("dealId") for p in out],
        sizes=[p.get("size") for p in out],
        upls=[p.get("upl") for p in out],
    )

    return out


# ======================================================================
# RESOLUTION EMPIRIQUE DU VRAI DEAL ID
# ======================================================================

def extract_deal_candidates(confirm: Dict[str, Any]) -> List[Dict[str, Any]]:
    candidates: List[Dict[str, Any]] = []

    main = confirm.get("dealId")
    if main:
        candidates.append({
            "source": "confirm.dealId",
            "dealId": str(main),
            "status": confirm.get("status"),
        })

    affected = confirm.get("affectedDeals") or []
    if isinstance(affected, list):
        for i, item in enumerate(affected):
            if not isinstance(item, dict):
                continue
            did = item.get("dealId")
            if did:
                candidates.append({
                    "source": f"affectedDeals[{i}].dealId",
                    "dealId": str(did),
                    "status": item.get("status"),
                })

    seen = set()
    unique = []
    for c in candidates:
        did = c.get("dealId")
        if did and did not in seen:
            unique.append(c)
            seen.add(did)

    return unique


def resolve_real_deal_id(headers: Dict[str, str], confirm: Dict[str, Any]) -> Tuple[bool, Optional[str], Optional[Dict[str, Any]], Dict[str, Any]]:
    candidates = extract_deal_candidates(confirm)
    candidate_ids = [c["dealId"] for c in candidates if c.get("dealId")]

    log(
        "RUNNER_DEAL_ID_CANDIDATES",
        asset=ASSET,
        dealReference=confirm.get("dealReference"),
        candidates=candidates,
    )

    if not candidate_ids:
        return False, None, None, {
            "reason": "NO_DEAL_ID_CANDIDATES",
            "confirm": confirm,
        }

    last_seen_positions: List[Dict[str, Any]] = []

    for attempt, delay in enumerate(POSITION_BACKOFFS, start=1):
        time.sleep(delay)

        positions = asset_positions(headers, ASSET)
        last_seen_positions = positions

        visible_ids = [str(p.get("dealId")) for p in positions if p.get("dealId")]

        log(
            "RUNNER_RESOLVE_DEAL_ID_ATTEMPT",
            asset=ASSET,
            attempt=attempt,
            delay=delay,
            candidate_ids=candidate_ids,
            visible_ids=visible_ids,
            positions=positions,
        )

        for p in positions:
            did = str(p.get("dealId"))
            if did in candidate_ids:
                log(
                    "RUNNER_REAL_DEAL_ID_RESOLVED",
                    asset=ASSET,
                    real_deal_id=did,
                    matched_position=p,
                    attempt=attempt,
                )
                return True, did, p, {
                    "attempt": attempt,
                    "candidate_ids": candidate_ids,
                    "visible_ids": visible_ids,
                }

    return False, None, None, {
        "reason": "NO_CANDIDATE_VISIBLE_AFTER_BACKOFF",
        "candidate_ids": candidate_ids,
        "last_seen_positions": last_seen_positions,
        "confirm": confirm,
    }


def confirm_reference(headers: Dict[str, str], deal_ref: str) -> Tuple[bool, Dict[str, Any]]:
    time.sleep(CONFIRM_POLL_SEC)

    status, data = api_get(headers, f"/confirms/{deal_ref}")

    ok = (
        status == 200
        and isinstance(data, dict)
        and data.get("dealStatus") == "ACCEPTED"
        and data.get("epic") == ASSET
        and bool(data.get("dealId") or data.get("affectedDeals"))
    )

    log(
        "RUNNER_CONFIRM_RESULT",
        asset=ASSET,
        dealReference=deal_ref,
        status=status,
        ok=ok,
        confirm=data,
    )

    return ok, data if isinstance(data, dict) else {"raw": data}


