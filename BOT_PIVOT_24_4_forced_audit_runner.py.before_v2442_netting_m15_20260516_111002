def next_side_and_size() -> Tuple[str, float, int]:
    side, size, seq = FAS.next_forced_order()

    if SIDE_MODE == "BUY_ONLY":
        side = "BUY"
    elif SIDE_MODE == "SELL_ONLY":
        side = "SELL"
    elif SIDE_MODE == "ALTERNATE":
        pass
    else:
        side = "BUY"

    return side, float(size), int(seq)


def open_market_broker_safe(
    headers: Dict[str, str],
    side: str,
    size: float,
    seq: int,
) -> Tuple[bool, Dict[str, Any]]:
    before_positions = asset_positions(headers, ASSET)

    client_ref = f"V2441_RECYCLE_{int(time.time())}_{seq}_{uuid.uuid4().hex[:6]}"

    payload = {
        "epic": ASSET,
        "direction": side,
        "size": float(size),
        "orderType": "MARKET",
        "guaranteedStop": GUARANTEED_STOP,
        "forceOpen": True,
        "stopDistance": STOP_DISTANCE,
    }

    log(
        "RUNNER_DIRECT_OPEN_REQUEST",
        asset=ASSET,
        side=side,
        size=size,
        seq=seq,
        client_ref=client_ref,
        payload=payload,
    )

    status, data = api_post(headers, "/positions", payload)

    log(
        "RUNNER_DIRECT_OPEN_RESPONSE",
        asset=ASSET,
        side=side,
        size=size,
        seq=seq,
        status=status,
        response=data,
    )

    # POST ambigu : exception, status 0, pas de dealReference.
    # On vérifie quand même /positions par différence.
    if status not in (200, 201) or not isinstance(data, dict) or not data.get("dealReference"):
        recovered_ok, real_deal_id, visible_position, recovery_debug = _verify_new_position_after_open(
            headers=headers,
            before_positions=before_positions,
            reason="POST_AMBIGUOUS_OR_FAILED",
            context={
                "status": status,
                "response": data,
                "payload": payload,
            },
        )

        if recovered_ok:
            return True, {
                "stage": "OPEN_RECOVERED_POST_AMBIGUOUS",
                "real_deal_id": real_deal_id,
                "position": visible_position,
                "recovery_debug": recovery_debug,
                "payload": payload,
            }

        return False, {
            "stage": "POST_POSITION_FAILED_VERIFIED_ABSENT",
            "status": status,
            "response": data,
            "recovery_debug": recovery_debug,
            "payload": payload,
        }

    deal_ref = data["dealReference"]

    confirm_ok, confirm = confirm_reference(headers, deal_ref)

    if not confirm_ok:
        recovered_ok, real_deal_id, visible_position, recovery_debug = _verify_new_position_after_open(
            headers=headers,
            before_positions=before_positions,
            reason="CONFIRM_NOT_ACCEPTED_OR_UNAVAILABLE",
            context={
                "dealReference": deal_ref,
                "confirm": confirm,
                "payload": payload,
            },
        )

        if recovered_ok:
            return True, {
                "stage": "OPEN_RECOVERED_CONFIRM_FAILED",
                "dealReference": deal_ref,
                "real_deal_id": real_deal_id,
                "position": visible_position,
                "confirm": confirm,
                "recovery_debug": recovery_debug,
                "payload": payload,
            }

        lock_runner(
            "CONFIRM_NOT_ACCEPTED_AND_NO_POSITION_RECOVERED",
            dealReference=deal_ref,
            confirm=confirm,
            recovery_debug=recovery_debug,
        )

        return False, {
            "stage": "CONFIRM_NOT_ACCEPTED_AND_NO_POSITION_RECOVERED",
            "dealReference": deal_ref,
            "confirm": confirm,
            "recovery_debug": recovery_debug,
        }

    resolved_ok, real_deal_id, visible_position, resolve_debug = resolve_real_deal_id(headers, confirm)

    if not resolved_ok:
        recovered_ok, recovered_deal_id, recovered_position, recovery_debug = _verify_new_position_after_open(
            headers=headers,
            before_positions=before_positions,
            reason="CONFIRMED_BUT_CANDIDATE_NOT_VISIBLE",
            context={
                "dealReference": deal_ref,
                "confirm": confirm,
                "resolve_debug": resolve_debug,
                "payload": payload,
            },
        )

        if recovered_ok:
            return True, {
                "stage": "OPEN_RECOVERED_CANDIDATE_NOT_VISIBLE",
                "dealReference": deal_ref,
                "real_deal_id": recovered_deal_id,
                "position": recovered_position,
                "confirm": confirm,
                "resolve_debug": resolve_debug,
                "recovery_debug": recovery_debug,
                "payload": payload,
            }

        lock_runner(
            "CONFIRMED_BUT_NO_POSITION_VISIBLE_AFTER_RECOVERY",
            dealReference=deal_ref,
            confirm=confirm,
            resolve_debug=resolve_debug,
            recovery_debug=recovery_debug,
        )

        return False, {
            "stage": "CONFIRMED_BUT_NO_POSITION_VISIBLE_AFTER_RECOVERY",
            "dealReference": deal_ref,
            "confirm": confirm,
            "resolve_debug": resolve_debug,
            "recovery_debug": recovery_debug,
        }

    return True, {
        "stage": "OPEN_CONFIRMED_AND_VISIBLE",
        "dealReference": deal_ref,
        "real_deal_id": real_deal_id,
        "confirm": confirm,
        "position": visible_position,
        "resolve_debug": resolve_debug,
        "payload": payload,
    }


def close_eth_position_direct(
    headers: Dict[str, str],
    deal_id: str,
    reason: str = "V2441_DIRECT_CLOSE",
) -> Tuple[bool, Dict[str, Any]]:
    positions = asset_positions(headers, ASSET)
    target = None

    for p in positions:
        if str(p.get("dealId")) == str(deal_id):
            target = p
            break

    if not target:
        return False, {
            "stage": "DEAL_ID_NOT_VISIBLE_BEFORE_CLOSE",
            "dealId": deal_id,
            "visible_dealIds": [p.get("dealId") for p in positions],
        }

    if target.get("epic") in PROTECTED_ASSETS:
        return False, {
            "stage": "PROTECTED_ASSET_CLOSE_BLOCKED",
            "position": target,
        }

    mark_close_attempt(deal_id)

    status, data = api_delete(headers, f"/positions/{deal_id}")

    log(
        "RUNNER_DIRECT_CLOSE_RESPONSE",
        asset=ASSET,
        dealId=deal_id,
        status=status,
        response=data,
        reason=reason,
        target=target,
    )

    close_ref = data.get("dealReference") if isinstance(data, dict) else None
    confirm_close = None

    if close_ref:
        time.sleep(1)
        cstatus, cdata = api_get(headers, f"/confirms/{close_ref}")
        confirm_close = {
            "status": cstatus,
            "data": cdata,
        }

        log(
            "RUNNER_DIRECT_CLOSE_CONFIRM",
            asset=ASSET,
            dealId=deal_id,
            closeReference=close_ref,
            status=cstatus,
            confirm=cdata,
        )

    # Vérification disparition de /positions
    still_visible = True
    last_positions = []

    for attempt, delay in enumerate(POSITION_BACKOFFS, start=1):
        time.sleep(delay)
        positions_after = asset_positions(headers, ASSET)
        last_positions = positions_after
        ids_after = position_ids(positions_after)

        log(
            "RUNNER_CLOSE_VISIBILITY_CHECK",
            asset=ASSET,
            dealId=deal_id,
            attempt=attempt,
            delay=delay,
            ids_after=sorted(ids_after),
        )

        if str(deal_id) not in ids_after:
            still_visible = False
            break

    ok = status in (200, 201) and not still_visible

    if ok:
        unmark_open(deal_id)

    return ok, {
        "stage": "CLOSE_SENT_AND_CHECKED",
        "dealId": deal_id,
        "status": status,
        "response": data,
        "confirm_close": confirm_close,
        "still_visible": still_visible,
        "last_positions": last_positions,
    }


def register_close_safe(deal_id: str, reason: str, extra: Dict[str, Any]) -> None:
    """
    FAS.register_close peut être absent selon la version du module FAS.
    On ne casse jamais la boucle pour ça.
    """
    try:
        fn = getattr(FAS, "register_close", None)
        if callable(fn):
            fn(
                asset=ASSET,
                dealId=deal_id,
                reason=reason,
                extra=extra,
            )
        else:
            log(
                "RUNNER_FAS_REGISTER_CLOSE_MISSING",
                asset=ASSET,
                dealId=deal_id,
                reason=reason,
                extra=extra,
            )
    except Exception as e:
        log(
            "RUNNER_FAS_REGISTER_CLOSE_EXCEPTION",
            asset=ASSET,
            dealId=deal_id,
            reason=reason,
            exception=repr(e),
            extra=extra,
        )


def close_aged_positions(headers: Dict[str, str]) -> None:
    """
    ADD-1 :
    Ferme toute position ETH dont l'âge local dépasse MAX_POSITION_AGE_SEC.
    Une position visible mais inconnue localement est enregistrée puis vieillit normalement.
    GOLD ne remonte jamais ici car asset_positions l'exclut.
    """
    sync_local_open_registry(headers)

    positions = asset_positions(headers, ASSET)

    for p in positions:
        did = p.get("dealId")
        if not did:
            continue

        did = str(did)
        age = local_age_sec(did)

        if age is None:
            mark_open(did)
            age = local_age_sec(did)

        log(
            "RUNNER_POSITION_AGE",
            asset=ASSET,
            dealId=did,
            age_sec=age,
            max_age_sec=MAX_POSITION_AGE_SEC,
            position=p,
        )

        if age is None:
            continue

        if age < MAX_POSITION_AGE_SEC:
            continue

        if close_recently_attempted(did):
            log(
                "RUNNER_CLOSE_BY_AGE_SKIPPED_COOLDOWN",
                asset=ASSET,
                dealId=did,
                age_sec=age,
                cooldown_sec=CLOSE_COOLDOWN_SEC,
            )
            continue

        ok, info = close_eth_position_direct(
            headers=headers,
            deal_id=did,
            reason="V2441_CLOSE_BY_AGE",
        )

        log(
            "RUNNER_CLOSE_BY_AGE",
            asset=ASSET,
            dealId=did,
            age_sec=age,
            ok=ok,
            info=info,
        )

        if ok:
            register_close_safe(
                deal_id=did,
                reason="V2441_CLOSE_BY_AGE",
                extra=info,
            )
        else:
            # Si fermeture demandée mais non vérifiée, on verrouille.
            lock_runner(
                "CLOSE_BY_AGE_FAILED",
                dealId=did,
                age_sec=age,
                info=info,
            )
            return


def close_pair_mechanical_if_enabled(headers: Dict[str, str]) -> None:
    """
    Présent mais désactivé par défaut.
    V24.4.1 : la paire reste hors stratégie, activation uniquement test mécanique.
    """
    if not PAIR_CLOSE_ENABLED:
        return

    positions = asset_positions(headers, ASSET)

    records = []
    for p in positions:
        records.append({
            "asset": ASSET,
            "epic": ASSET,
            "dealId": p.get("dealId"),
            "brokerDealId": p.get("dealId"),
            "size": p.get("size"),
            "direction": p.get("direction"),
            "broker_upl": p.get("upl"),
            "raw": p,
        })

    pair = FAS.select_close_pair_from_records(ASSET, records)

    if not pair:
        log("RUNNER_PAIR_NO_MATCH", asset=ASSET, count=len(records))
        return

    weak, strong = pair

    log("RUNNER_PAIR_SELECTED_MECHANICAL", asset=ASSET, weak=weak, strong=strong)

    closed = []

    for rec in (weak, strong):
        did = rec.get("brokerDealId") or rec.get("dealId")
        if not did:
            closed.append({"dealId": None, "ok": False, "reason": "MISSING_DEAL_ID"})
            continue

        ok, info = close_eth_position_direct(
            headers=headers,
            deal_id=did,
            reason="V2441_PAIR_MECHANICAL_CLOSE",
        )

        closed.append({
            "dealId": did,
            "ok": ok,
            "info": info,
        })

    try:
        FAS.register_close_pair(ASSET, weak, strong, reason="V2441_PAIR_MECHANICAL_CLOSE")
    except Exception as e:
        log("RUNNER_REGISTER_CLOSE_PAIR_EXCEPTION", asset=ASSET, exception=repr(e))

    log("RUNNER_PAIR_CLOSE_DONE", asset=ASSET, closed=closed)


# ======================================================================
# RATE LIMITER LOCAL — 2 OUVERTURES / 60 SECONDES
# ======================================================================

def prune_open_window(now: Optional[float] = None) -> None:
    now = now or time.time()
    cutoff = now - 60.0

    while _open_ts_window and _open_ts_window[0] < cutoff:
        _open_ts_window.pop(0)


def opens_last_60s() -> int:
    prune_open_window()
    return len(_open_ts_window)


def can_open_now() -> Tuple[bool, Dict[str, Any]]:
    now = time.time()
    prune_open_window(now)

    count = len(_open_ts_window)

    if count >= TARGET_OPENINGS_PER_MIN:
        return False, {
            "reason": "RATE_LIMIT_REACHED",
            "opens_last_60s": count,
            "target_openings_per_min": TARGET_OPENINGS_PER_MIN,
            "window": list(_open_ts_window),
        }

    return True, {
        "reason": "RATE_LIMIT_OK",
        "opens_last_60s": count,
        "target_openings_per_min": TARGET_OPENINGS_PER_MIN,
    }


def register_open_window() -> None:
    _open_ts_window.append(time.time())
    prune_open_window()


# ======================================================================
# MAIN LOOP
# ======================================================================

def main() -> None:
    FAS.safety_banner()

    if ASSET in PROTECTED_ASSETS:
        raise RuntimeError(f"ASSET {ASSET} is protected and cannot be traded")

    refuse_if_lock_present()

    log(
        "RUNNER_V2441_START",
        asset=ASSET,
        protected_assets=list(PROTECTED_ASSETS),
        target_openings_per_min=TARGET_OPENINGS_PER_MIN,
        sleep_sec=SLEEP_SEC,
        max_positions=MAX_POSITIONS,
        side_mode=SIDE_MODE,
        guaranteed_stop=GUARANTEED_STOP,
        stop_distance=STOP_DISTANCE,
        max_position_age_sec=MAX_POSITION_AGE_SEC,
        close_cooldown_sec=CLOSE_COOLDOWN_SEC,
        pair_close_enabled=PAIR_CLOSE_ENABLED,
        backoffs=POSITION_BACKOFFS,
        base=BASE,
    )

    headers = ensure_headers(G.login())
    log("RUNNER_LOGIN_OK", asset=ASSET)

    while True:
        try:
            if is_locked():
                log("RUNNER_HALTED_BY_LOCK", asset=ASSET, lock_file=LOCK_FILE)
                time.sleep(60)
                continue

            # 1. Synchroniser les positions visibles.
            sync_local_open_registry(headers)

            # 2. Fermer les positions âgées pour recycler les slots.
            close_aged_positions(headers)

            # 3. Fermeture par paire mécanique uniquement si activée explicitement.
            close_pair_mechanical_if_enabled(headers)

            # 4. Relire les positions après éventuelles fermetures.
            positions = asset_positions(headers, ASSET)

            rate_ok, rate_info = can_open_now()

            log(
                "RUNNER_STATUS",
                asset=ASSET,
                open_positions=len(positions),
                open_dealIds=[p.get("dealId") for p in positions],
                opens_last_60s=opens_last_60s(),
                target_openings_per_min=TARGET_OPENINGS_PER_MIN,
                max_positions=MAX_POSITIONS,
                rate_ok=rate_ok,
                rate_info=rate_info,
                local_open_registry=dict(_local_open_ts),
            )

            # 5. Blocage si MAX_POSITIONS atteint.
            if len(positions) >= MAX_POSITIONS:
                log(
                    "RUNNER_OPEN_BLOCKED",
                    asset=ASSET,
                    reason="MAX_POSITIONS_REACHED",
                    open_positions=len(positions),
                    max_positions=MAX_POSITIONS,
                    dealIds=[p.get("dealId") for p in positions],
                )
                time.sleep(SLEEP_SEC)
                continue

            # 6. Blocage si cadence 60 s atteinte.
            if not rate_ok:
                log(
                    "RUNNER_OPEN_BLOCKED",
                    asset=ASSET,
                    reason=rate_info.get("reason"),
                    rate_info=rate_info,
                )
                time.sleep(SLEEP_SEC)
                continue

            # 7. Ouverture au plus une position par itération.
            side, size, seq = next_side_and_size()

            ok, info = open_market_broker_safe(
                headers=headers,
                side=side,
                size=size,
                seq=seq,
            )

            log(
                "RUNNER_OPEN_RESULT",
                asset=ASSET,
                side=side,
                size=size,
                seq=seq,
                ok=ok,
                info=info,
            )

            if ok:
                register_open_window()

                try:
                    FAS.register_open(
                        asset=ASSET,
                        side=side,
                        size=size,
                        reason="V2441_RECYCLE_CONFIRMED_VISIBLE_OPEN",
                        extra=info,
                    )
                except Exception as e:
                    log(
                        "RUNNER_FAS_REGISTER_OPEN_EXCEPTION",
                        asset=ASSET,
                        exception=repr(e),
                        info=info,
                    )

            time.sleep(SLEEP_SEC)

        except Exception as e:
            msg = str(e)

            log(
                "RUNNER_EXCEPTION",
                asset=ASSET,
                exception=msg,
                traceback=traceback.format_exc().replace("\n", " / "),
            )

            if "429" in msg or "too-many" in msg.lower() or "session" in msg.lower():
                time.sleep(120)
                headers = ensure_headers(G.login())
                log("RUNNER_RELOGIN_OK", asset=ASSET)
            else:
                time.sleep(20)


if __name__ == "__main__":
    main()
