def get_positions_raw(headers: Dict[str, str]) -> List[Dict[str, Any]]:
    status, data = api_get(headers, "/positions")

    if status != 200:
        log("RUNNER_GET_POSITIONS_ERROR", asset=ASSET, status=status, response=data)
        raise RuntimeError(f"GET /positions failed status={status} data={data}")

    positions = data.get("positions", []) if isinstance(data, dict) else []

    log(
        "RUNNER_GET_POSITIONS_OK",
        asset=ASSET,
        status=status,
        total_positions=len(positions),
        raw=data,
    )

    return positions


def position_epic(item: Dict[str, Any]) -> str:
    if not isinstance(item, dict):
        return ""

    market = item.get("market", {}) if isinstance(item.get("market"), dict) else {}
    position = item.get("position", {}) if isinstance(item.get("position"), dict) else {}

    return str(
        market.get("epic")
        or position.get("epic")
        or item.get("epic")
        or ""
    ).upper()


def normalize_position(item: Dict[str, Any]) -> Dict[str, Any]:
    market = item.get("market", {}) if isinstance(item.get("market"), dict) else {}
    position = item.get("position", {}) if isinstance(item.get("position"), dict) else {}

    def fnum(v: Any, default: float = 0.0) -> float:
        try:
            if v is None:
                return default
            return float(v)
        except Exception:
            return default

    return {
        "epic": str(market.get("epic") or position.get("epic") or item.get("epic") or "").upper(),
        "dealId": position.get("dealId") or item.get("dealId"),
        "dealReference": position.get("dealReference") or item.get("dealReference"),
        "workingOrderId": position.get("workingOrderId") or item.get("workingOrderId"),
        "size": fnum(position.get("size") or item.get("size")),
        "direction": position.get("direction") or item.get("direction"),
        "level": fnum(position.get("level") or item.get("level")),
        "upl": fnum(position.get("upl") or item.get("upl")),
        "guaranteedStop": bool(position.get("guaranteedStop") or item.get("guaranteedStop")),
        "raw": item,
    }


def asset_positions(headers: Dict[str, str], asset: str = ASSET) -> List[Dict[str, Any]]:
    raw_positions = get_positions_raw(headers)
    out: List[Dict[str, Any]] = []

    for item in raw_positions:
        epic = position_epic(item)

        # GOLD est protégé : jamais retourné à la logique ETH.
        if epic in PROTECTED_ASSETS:
            log(
                "RUNNER_PROTECTED_POSITION_SKIPPED",
                asset=ASSET,
                protected_epic=epic,
                raw=item,
            )
            continue

        if epic == asset:
            out.append(normalize_position(item))

    log(
        "RUNNER_ASSET_POSITIONS",
        asset=asset,
        count=len(out),
        dealIds=[p.get("dealId") for p in out],
        sizes=[p.get("size") for p in out],
        upls=[p.get("upl") for p in out],
    )

    return out


def mark_open(deal_id: str, opened_ts: Optional[float] = None) -> None:
    if not deal_id:
        return

    did = str(deal_id)
    if did not in _local_open_ts:
        _local_open_ts[did] = opened_ts or time.time()
        log(
            "RUNNER_MARK_OPEN",
            asset=ASSET,
            dealId=did,
            opened_ts=_local_open_ts[did],
        )


def unmark_open(deal_id: str) -> None:
    if not deal_id:
        return

    did = str(deal_id)
    if did in _local_open_ts:
        _local_open_ts.pop(did, None)
        log(
            "RUNNER_UNMARK_OPEN",
            asset=ASSET,
            dealId=did,
        )


def mark_close_attempt(deal_id: str) -> None:
    if deal_id:
        _close_attempt_ts[str(deal_id)] = time.time()


def close_recently_attempted(deal_id: str) -> bool:
    if not deal_id:
        return False

    last = _close_attempt_ts.get(str(deal_id))

    if not last:
        return False

    return (time.time() - last) < CLOSE_COOLDOWN_SEC


def sync_local_open_registry(headers: Dict[str, str]) -> None:
    """
    Enregistre localement les positions ETH visibles mais pas encore connues.
    Utile si le runner redémarre alors qu'une position ETH existe déjà.
    GOLD reste ignoré.
    """
    now = time.time()
    positions = asset_positions(headers, ASSET)

    for p in positions:
        did = p.get("dealId")
        if did and str(did) not in _local_open_ts:
            _local_open_ts[str(did)] = now
            log(
                "RUNNER_LOCAL_OPEN_SYNC",
                asset=ASSET,
                dealId=did,
                reason="VISIBLE_POSITION_NOT_IN_LOCAL_REGISTRY",
                position=p,
            )


def local_age_sec(deal_id: str) -> Optional[float]:
    if not deal_id:
        return None

    ts = _local_open_ts.get(str(deal_id))
    if not ts:
        return None

    return max(0.0, time.time() - ts)


def position_ids(positions: List[Dict[str, Any]]) -> set:
    return {str(p.get("dealId")) for p in positions if p.get("dealId")}


