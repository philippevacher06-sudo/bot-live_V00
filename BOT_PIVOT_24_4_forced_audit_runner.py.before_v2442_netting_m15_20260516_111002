def log(event: str, **kw: Any) -> None:
    try:
        FAS.audit_log(event, **kw)
    except Exception:
        print(event, kw)


def ensure_headers(headers: Dict[str, str]) -> Dict[str, str]:
    h = dict(headers or {})
    h.setdefault("Content-Type", "application/json")
    h.setdefault("Accept", "application/json")
    return h


def lock_runner(reason: str, **kw: Any) -> None:
    os.makedirs("data/execution", exist_ok=True)

    with open(LOCK_FILE, "w", encoding="utf-8") as f:
        f.write(f"reason={reason}\n")
        f.write(f"ts_utc={time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime())}\n")
        for k, v in kw.items():
            try:
                f.write(f"{k}={json.dumps(v, ensure_ascii=False)}\n")
            except Exception:
                f.write(f"{k}={repr(v)}\n")

    log("RUNNER_LOCKED", asset=ASSET, reason=reason, **kw)


def is_locked() -> bool:
    return os.path.exists(LOCK_FILE)


def refuse_if_lock_present() -> None:
    if is_locked():
        log("RUNNER_LOCK_PRESENT_AT_START", asset=ASSET, lock_file=LOCK_FILE)
        raise RuntimeError(
            f"LOCK actif : {LOCK_FILE}. "
            f"Faire reconcile propre puis supprimer manuellement : rm -f {LOCK_FILE}"
        )


