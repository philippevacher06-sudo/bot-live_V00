def extract_deal_candidates(confirm: Dict[str, Any]) -> List[Dict[str, Any]]:
    candidates: List[Dict[str, Any]] = []

    main = confirm.get("dealId")
    if main:
        candidates.append({
            "source": "confirm.dealId",
            "dealId": str(main),
            "status": confirm.get("status"),
        })

    affected = confirm.get("affectedDeals") or []
    if isinstance(affected, list):
        for i, item in enumerate(affected):
            if not isinstance(item, dict):
                continue
            did = item.get("dealId")
            if did:
                candidates.append({
                    "source": f"affectedDeals[{i}].dealId",
                    "dealId": str(did),
                    "status": item.get("status"),
                })

    seen = set()
    unique = []
    for c in candidates:
        did = c.get("dealId")
        if did and did not in seen:
            unique.append(c)
            seen.add(did)

    return unique


def resolve_real_deal_id(
    headers: Dict[str, str],
    confirm: Dict[str, Any],
) -> Tuple[bool, Optional[str], Optional[Dict[str, Any]], Dict[str, Any]]:
    candidates = extract_deal_candidates(confirm)
    candidate_ids = [c["dealId"] for c in candidates if c.get("dealId")]

    log(
        "RUNNER_DEAL_ID_CANDIDATES",
        asset=ASSET,
        dealReference=confirm.get("dealReference"),
        candidates=candidates,
    )

    if not candidate_ids:
        return False, None, None, {
            "reason": "NO_DEAL_ID_CANDIDATES",
            "confirm": confirm,
        }

    last_seen_positions: List[Dict[str, Any]] = []

    for attempt, delay in enumerate(POSITION_BACKOFFS, start=1):
        time.sleep(delay)

        positions = asset_positions(headers, ASSET)
        last_seen_positions = positions

        visible_ids = [str(p.get("dealId")) for p in positions if p.get("dealId")]

        log(
            "RUNNER_RESOLVE_DEAL_ID_ATTEMPT",
            asset=ASSET,
            attempt=attempt,
            delay=delay,
            candidate_ids=candidate_ids,
            visible_ids=visible_ids,
            positions=positions,
        )

        for p in positions:
            did = str(p.get("dealId"))
            if did in candidate_ids:
                mark_open(did)
                log(
                    "RUNNER_REAL_DEAL_ID_RESOLVED",
                    asset=ASSET,
                    real_deal_id=did,
                    matched_position=p,
                    attempt=attempt,
                )
                return True, did, p, {
                    "attempt": attempt,
                    "candidate_ids": candidate_ids,
                    "visible_ids": visible_ids,
                }

    return False, None, None, {
        "reason": "NO_CANDIDATE_VISIBLE_AFTER_BACKOFF",
        "candidate_ids": candidate_ids,
        "last_seen_positions": last_seen_positions,
        "confirm": confirm,
    }


def confirm_reference(headers: Dict[str, str], deal_ref: str) -> Tuple[bool, Dict[str, Any]]:
    """
    FIX-1 :
    Capital.com ne renvoie pas toujours epic dans /confirms.
    On échoue seulement si epic est présent ET différent de ASSET.
    """
    time.sleep(CONFIRM_POLL_SEC)

    status, data = api_get(headers, f"/confirms/{deal_ref}")

    epic = data.get("epic") if isinstance(data, dict) else None
    epic_ok = (not epic) or (str(epic).upper() == ASSET)

    ok = (
        status == 200
        and isinstance(data, dict)
        and data.get("dealStatus") == "ACCEPTED"
        and epic_ok
        and bool(data.get("dealId") or data.get("affectedDeals"))
    )

    log(
        "RUNNER_CONFIRM_RESULT",
        asset=ASSET,
        dealReference=deal_ref,
        status=status,
        ok=ok,
        epic_present=bool(epic),
        epic=epic,
        confirm=data,
    )

    return ok, data if isinstance(data, dict) else {"raw": data}


def _verify_new_position_after_open(
    headers: Dict[str, str],
    before_positions: List[Dict[str, Any]],
    reason: str,
    context: Dict[str, Any],
) -> Tuple[bool, Optional[str], Optional[Dict[str, Any]], Dict[str, Any]]:
    """
    FIX-2 :
    Sur POST ambigu ou confirm/résolution échouée, on vérifie par différence
    si une nouvelle position ETH est apparue dans /positions.
    """
    before_ids = position_ids(before_positions)
    last_positions: List[Dict[str, Any]] = []

    for attempt, delay in enumerate(POSITION_BACKOFFS, start=1):
        time.sleep(delay)

        after_positions = asset_positions(headers, ASSET)
        last_positions = after_positions
        after_ids = position_ids(after_positions)
        new_ids = sorted(after_ids - before_ids)

        log(
            "RUNNER_VERIFY_NEW_POSITION_AFTER_OPEN",
            asset=ASSET,
            reason=reason,
            attempt=attempt,
            delay=delay,
            before_ids=sorted(before_ids),
            after_ids=sorted(after_ids),
            new_ids=new_ids,
            context=context,
        )

        if new_ids:
            real_id = new_ids[0]
            matched = None

            for p in after_positions:
                if str(p.get("dealId")) == real_id:
                    matched = p
                    break

            mark_open(real_id)

            log(
                "RUNNER_OPEN_RECOVERED_BY_POSITION_DIFF",
                asset=ASSET,
                real_deal_id=real_id,
                matched_position=matched,
                reason=reason,
                context=context,
            )

            return True, real_id, matched, {
                "stage": "OPEN_RECOVERED_BY_POSITION_DIFF",
                "reason": reason,
                "before_ids": sorted(before_ids),
                "new_ids": new_ids,
                "context": context,
            }

    return False, None, None, {
        "stage": "POST_POSITION_FAILED_VERIFIED_ABSENT",
        "reason": reason,
        "before_ids": sorted(before_ids),
        "last_seen_positions": last_positions,
        "context": context,
    }


